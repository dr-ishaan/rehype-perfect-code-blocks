{
  "name": "rehype-perfect-code-blocks",
  "version": "1.0.0",
  "description": "Beautiful, configurable code blocks for Astro / MDX / any rehype pipeline. Wraps Shiki output with a styled header, line numbers, copy button, line highlighting, diff, focus, error levels, word highlights, captions, and per-block overrides. Inspired by rehype-pretty-code, VitePress, Docusaurus, and Expressive Code.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./astro": {
      "types": "./dist/astro.d.ts",
      "import": "./dist/astro.js"
    },
    "./remark": {
      "types": "./dist/remark.d.ts",
      "import": "./dist/remark.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && cp src/styles.css dist/styles.css",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "node test-edge-cases.mjs && node stress-tests.mjs && node new-feature-tests.mjs",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "rehype",
    "astro",
    "shiki",
    "code-block",
    "syntax-highlighting",
    "mdx",
    "markdown",
    "rehype-pretty-code",
    "vitepress",
    "docusaurus"
  ],
  "license": "MIT",
  "author": "",
  "peerDependencies": {
    "astro": "^4.0.0 || ^5.0.0"
  },
  "peerDependenciesMeta": {
    "astro": {
      "optional": true
    },
    "shiki": {
      "optional": true
    }
  },
  "dependencies": {
    "@shikijs/transformers": "^4.2.0",
    "hast": "^1.0.0",
    "hast-util-from-html": "^2.0.0",
    "unist-util-visit": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "astro": "^5.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "shiki": "^1.0.0",
    "typescript": "^5.4.0",
    "unified": "^11.0.5"
  }
}
