{
  "name": "@dr-ishaan/rehype-perfect-code-blocks",
  "version": "1.2.1",
  "description": "Beautiful, configurable code blocks for Astro / MDX / any rehype pipeline. Built on Shiki, inspired by rehype-pretty-code, VitePress, Docusaurus, and Expressive Code.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./astro": {
      "types": "./dist/astro.d.ts",
      "import": "./dist/astro.js"
    },
    "./remark": {
      "types": "./dist/remark.d.ts",
      "import": "./dist/remark.js"
    },
    "./meta": {
      "types": "./dist/meta.d.ts",
      "import": "./dist/meta.js"
    },
    "./transformer": {
      "types": "./dist/transformer.d.ts",
      "import": "./dist/transformer.js"
    },
    "./shiki": {
      "types": "./dist/shiki.d.ts",
      "import": "./dist/shiki.js"
    },
    "./copy-script": {
      "types": "./dist/copy-script.d.ts",
      "import": "./dist/copy-script.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && cp src/styles.css dist/styles.css",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "node test-meta-parser.mjs && node test-dom-structure.mjs && node test-options.mjs && node test-notations.mjs && node test-security.mjs && node test-integration.mjs && node test-regression.mjs && node test-css.mjs && node test-edge-cases.mjs && node stress-tests.mjs && node new-feature-tests.mjs && node test-issue-12.mjs && node test-issue-11.mjs",
    "prepublishOnly": "npm run build && npm test",
    "prepack": "npm run build"
  },
  "keywords": [
    "rehype",
    "astro",
    "shiki",
    "code-block",
    "syntax-highlighting",
    "mdx",
    "markdown",
    "rehype-pretty-code",
    "vitepress",
    "docusaurus",
    "expressive-code",
    "remark",
    "highlight",
    "copy-button",
    "line-numbers"
  ],
  "license": "MIT",
  "author": "dr-ishaan <dr-ishaan@users.noreply.github.com>",
  "homepage": "https://github.com/dr-ishaan/rehype-perfect-code-blocks#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dr-ishaan/rehype-perfect-code-blocks.git"
  },
  "bugs": {
    "url": "https://github.com/dr-ishaan/rehype-perfect-code-blocks/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "astro": "^4.0.0 || ^5.0.0 || ^6.0.0"
  },
  "peerDependenciesMeta": {
    "astro": {
      "optional": true
    },
    "shiki": {
      "optional": true
    }
  },
  "dependencies": {
    "@shikijs/transformers": "^4.2.0",
    "hast": "^1.0.0",
    "hast-util-from-html": "^2.0.0",
    "unist-util-visit": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "astro": "^5.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "shiki": "^1.0.0",
    "typescript": "^5.4.0",
    "unified": "^11.0.5"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
